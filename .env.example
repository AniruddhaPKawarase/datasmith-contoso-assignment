# ─── Provider credentials ───
# OpenAI — for cheap/fast tasks (router, ambiguity, explain)
OPENAI_API_KEY=sk-replace-me
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic — for accuracy-critical tasks (SQL generation, composition, validation)
ANTHROPIC_API_KEY=sk-ant-replace-me
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_API_VERSION=2023-06-01

# Optional: OpenRouter as supplementary provider (free models, open-weights)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Local fallback
OLLAMA_BASE_URL=http://localhost:11434

# ─── Model routing per task ───
# Format: <provider>/<model_id>
# Cost-optimised: Anthropic Haiku for accuracy-critical, OpenAI Mini for cheap tasks.
# Estimated dev burn: ~$0.10/day. Full Phase 10 eval: ~$8 total.

# Routing/classification — cheap, no SQL knowledge needed
LLM_MODEL_ROUTER=openai/gpt-4o-mini

# SQL generation (5 domain agents) — Haiku 4.5 matches Sonnet on code at 1/3 cost
LLM_MODEL_SQL_GEN=anthropic/claude-haiku-4-5

# Cross-domain composition (CTE merging) — needs reasoning quality
LLM_MODEL_COMPOSER=anthropic/claude-haiku-4-5

# Validation/error diagnosis — pinpoints which agent broke
LLM_MODEL_VALIDATOR=anthropic/claude-haiku-4-5

# Ambiguity detection + clarifying questions
LLM_MODEL_AMBIGUITY=openai/gpt-4o-mini

# Temporal fallback (primary path is deterministic Python — Objective #3)
LLM_MODEL_TEMPORAL=anthropic/claude-haiku-4-5

# NL explanation of generated SQL
LLM_MODEL_EXPLAIN=openai/gpt-4o-mini

# Fallback model used when the primary task model fails (any provider/model)
LLM_FALLBACK_MODEL=openai/gpt-4o-mini

# ─── PostgreSQL (Odoo) ───
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=odoo
POSTGRES_USER=odoo
POSTGRES_PASSWORD=odoo_dev_pwd

# ─── Odoo ───
ODOO_URL=http://odoo:8069
ODOO_DB=odoo
ODOO_USER=admin
ODOO_PASSWORD=admin

# ─── DuckDB (embedded) ───
DUCKDB_PATH=/data/analytics.duckdb

# ─── Redis ───
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ─── FastAPI ───
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# ─── Next.js ───
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Tracking ───
MLFLOW_TRACKING_URI=./mlruns

# ─── Limits ───
MAX_SQL_TIMEOUT_SECONDS=30
MAX_CORRECTION_ATTEMPTS=3
MAX_SCHEMA_TOKENS_PER_AGENT=4000
